PORT=5000
NODE_ENV=development

# Update this to your MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/tb-beauty

# Required for customer signup / login / checkout (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# WhatsApp order notification (Meta WhatsApp Cloud API)
# Keep disabled until all values are configured and template is approved.
WHATSAPP_NOTIFY_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=97451255068
WHATSAPP_TEMPLATE=order_notification
WHATSAPP_TEMPLATE_LANG=en

